{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuweichaox/DataAcquisition/schemas/device-config.schema.json",
  "title": "DataAcquisition Device Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SchemaVersion",
    "IsEnabled",
    "PlcCode",
    "Driver",
    "Host",
    "Port",
    "HeartbeatMonitorRegister",
    "HeartbeatPollingInterval",
    "Channels"
  ],
  "properties": {
    "SchemaVersion": {
      "type": "integer",
      "const": 1
    },
    "IsEnabled": {
      "type": "boolean"
    },
    "PlcCode": {
      "type": "string",
      "minLength": 1
    },
    "Driver": {
      "type": "string",
      "minLength": 1
    },
    "Host": {
      "type": "string",
      "minLength": 1
    },
    "Port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "ProtocolOptions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "HeartbeatMonitorRegister": {
      "type": "string",
      "minLength": 1
    },
    "HeartbeatPollingInterval": {
      "type": "integer",
      "minimum": 1
    },
    "Channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/channel"
      }
    }
  },
  "$defs": {
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ChannelCode",
        "EnableBatchRead",
        "Measurement",
        "BatchSize",
        "AcquisitionInterval",
        "AcquisitionMode"
      ],
      "properties": {
        "ChannelCode": {
          "type": "string",
          "minLength": 1
        },
        "EnableBatchRead": {
          "type": "boolean"
        },
        "BatchReadRegister": {
          "type": "string"
        },
        "BatchReadLength": {
          "type": "integer",
          "minimum": 0
        },
        "Measurement": {
          "type": "string",
          "minLength": 1
        },
        "BatchSize": {
          "type": "integer",
          "minimum": 1
        },
        "AcquisitionInterval": {
          "type": "integer",
          "minimum": 0
        },
        "AcquisitionMode": {
          "type": "string",
          "enum": ["Always", "Conditional"]
        },
        "ConditionalAcquisition": {
          "$ref": "#/$defs/conditionalAcquisition"
        },
        "Metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        }
      }
    },
    "conditionalAcquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Register",
        "DataType",
        "StartTriggerMode",
        "EndTriggerMode"
      ],
      "properties": {
        "Register": {
          "type": "string",
          "minLength": 1
        },
        "DataType": {
          "type": "string",
          "minLength": 1
        },
        "StartTriggerMode": {
          "type": "string",
          "enum": ["RisingEdge", "FallingEdge"]
        },
        "EndTriggerMode": {
          "type": "string",
          "enum": ["RisingEdge", "FallingEdge"]
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "MetricLabel",
        "FieldName",
        "Register",
        "Index",
        "DataType"
      ],
      "properties": {
        "MetricLabel": {
          "type": "string"
        },
        "FieldName": {
          "type": "string",
          "minLength": 1
        },
        "Register": {
          "type": "string",
          "minLength": 1
        },
        "Index": {
          "type": "integer",
          "minimum": 0
        },
        "DataType": {
          "type": "string",
          "minLength": 1
        },
        "EvalExpression": {
          "type": "string"
        },
        "StringByteLength": {
          "type": "integer",
          "minimum": 0
        },
        "Encoding": {
          "type": "string"
        }
      }
    }
  }
}
